local function GetPlayerRole(player)
    if not player then return "innocent" end
    
    if player.Character then
        for _, child in pairs(player.Character:GetChildren()) do
            if child:IsA("Tool") then
                local toolName = child.Name:lower()
                if toolName:find("knife") then return "murderer"
                elseif toolName:find("sheriff") or toolName:find("gun") then return "sheriff"
                end
            end
        end
    end
    
    if player.Backpack then
        for _, item in pairs(player.Backpack:GetChildren()) do
            if item:IsA("Tool") then
                local itemName = item.Name:lower()
                if itemName:find("knife") then return "murderer"
                elseif itemName:find("sheriff") or itemName:find("gun") then return "sheriff"
                end
            end
        end
    end
    return "innocent"
end

