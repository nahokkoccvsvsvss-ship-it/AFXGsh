-- ============= كتابة الكود في الشات =============
local function typeCode(code)
    -- فتح الشات
    VirtualInput:SendKeyEvent(true, Enum.KeyCode.Slash, false, game)
    task.wait(0.2)
    VirtualInput:SendKeyEvent(false, Enum.KeyCode.Slash, false, game)
    task.wait(0.1)
    
    -- كتابة الكود
    for i = 1, #code do
        local char = string.sub(code, i, i)
        VirtualInput:SendKeyEvent(true, char, false, game)
        task.wait(0.05)
        VirtualInput:SendKeyEvent(false, char, false, game)
    end
    task.wait(0.1)
    
    -- إرسال
    VirtualInput:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
    task.wait(0.1)
    VirtualInput:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
end

-- ============= المطالبة بجميع الرموز =============
local function claimAllCodes()
    if not autoClaimCodes then return end
    
    for _, codeInfo in pairs(CODES) do
        local code = codeInfo.code
        local reward = codeInfo.reward
        
        -- التحقق إذا كان الكود طالبته قبل
        if not claimedCodes[code] then
            typeCode(code)
            task.wait(1.5)
            claimedCodes[code] = true
            saveClaimedCodes()
            
            game.StarterGui:SetCore("SendNotification", {
                Title = "🎁 Auto Claim Codes",
                Text = "✅ تم المطالبة بـ: " .. code .. " - " .. reward,
                Duration = 3
            })
        end
        task.wait(1)
    end
end

